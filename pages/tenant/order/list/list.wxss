.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.header {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  margin-bottom: 20rpx;
  background: white;
  border-radius: 10rpx;
}

.back-btn {
  font-size: 40rpx;
  padding: 0 30rpx;
  color: #007AFF;
}

.title {
  flex: 1;
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-right: 70rpx;
}

.order-list {
  margin-top: 20rpx;
}

.order-item {
  background: white;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #eee;
}

.order-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.order-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.order-status.pending {
  background: #fff3e0;
  color: #ff9800;
}

.order-status.confirmed {
  background: #e8f5e9;
  color: #09BB07;
}

.order-status.completed {
  background: #e3f2fd;
  color: #007AFF;
}

.order-status.cancelled {
  background: #f5f5f5;
  color: #999;
}

.info-item {
  display: flex;
  margin-bottom: 10rpx;
  font-size: 28rpx;
}

.label {
  color: #666;
  width: 140rpx;
}

.value {
  color: #333;
  flex: 1;
}

.value.price {
  color: #ff6b35;
  font-weight: bold;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn-cancel, .btn-detail {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  border: none;
}

.btn-cancel {
  background: #ffebee;
  color: #ff3b30;
  border: 1rpx solid #ffcdd2;
}

.btn-detail {
  background: #e3f2fd;
  color: #007AFF;
  border: 1rpx solid #bbdefb;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.3;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.btn {
  background: #007AFF;
  color: white;
  border-radius: 30rpx;
  padding: 20rpx 60rpx;
  font-size: 30rpx;
  border: none;
}