/* pages/tenant/profile/profile.wxss */

.profile-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  padding: 30rpx;
  padding-bottom: 140rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  color: white;
  margin-bottom: 30rpx;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.3);
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  margin-right: 20rpx;
}

.user-info {
  flex: 1;
}

.username {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.user-status {
  font-size: 24rpx;
  opacity: 0.9;
}

.stats-grid {
  display: flex;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 通用卡片样式 */
.section-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.3s;
}

.section-card:active {
  transform: scale(0.98);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  display: flex;
  align-items: center;
}

.title-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-action {
  font-size: 26rpx;
  color: #007AFF;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(0, 122, 255, 0.1);
}

/* 订单列表 */
.order-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-item {
  display: flex;
  align-items: center;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-item:last-child {
  border-bottom: none;
}

.order-content {
  flex: 1;
}

.order-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 10rpx;
}

.order-time {
  font-size: 24rpx;
  color: #666;
  display: flex;
  align-items: center;
}

.time-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

.order-status {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-top: 10rpx;
}

.status-active {
  background: #e8f5e9;
  color: #09BB07;
}

.order-arrow {
  font-size: 36rpx;
  color: #999;
  margin-left: 20rpx;
}

/* 收藏网格 */
.fav-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.fav-item {
  display: flex;
  align-items: center;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.fav-item:last-child {
  border-bottom: none;
}

.fav-icon {
  font-size: 50rpx;
  margin-right: 20rpx;
}

.fav-info {
  flex: 1;
}

.fav-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.fav-price {
  font-size: 26rpx;
  color: #FF6B35;
  font-weight: 600;
}

.fav-tag {
  background: #fff3e0;
  color: #ff9800;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.3;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
}

/* 功能网格 */
.function-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.func-item {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
}

.func-item:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.func-icon {
  font-size: 50rpx;
  margin-bottom: 15rpx;
}

.func-label {
  font-size: 26rpx;
  color: #333;
}

/* 退出按钮 */
.logout-btn {
  background: white;
  color: #FF3B30;
  border-radius: 16rpx;
  height: 90rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: 2rpx solid #ffcdd2;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.logout-btn:active {
  background: #ffebee;
  transform: scale(0.98);
}

.logout-icon {
  margin-right: 15rpx;
  font-size: 36rpx;
}

/* 底部标签栏 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  display: flex;
  height: 120rpx;
  border-top: 1rpx solid #f0f0f0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 1000;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #999;
  transition: all 0.3s;
}

.tab-item.active {
  color: #007AFF;
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.tab-label {
  font-size: 24rpx;
}

.tab-item:active {
  opacity: 0.7;
}