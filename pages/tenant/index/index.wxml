<view class="container">
  <view class="card" wx:for="{{houses}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
    <image src="{{item.images[0] || item.image}}" mode="aspectFill" style="width:100%; height:320rpx;"/>
    <view style="padding: 20rpx 10rpx;">
      <view style="font-weight:bold; font-size:32rpx;">{{item.title}}</view>
      <view style="color:#666; font-size:26rpx; margin:10rpx 0;">{{item.type}} | {{item.area}}㎡</view>
      <view style="color:#ff4d4f; font-weight:bold; font-size:34rpx;">￥{{item.price}}/月</view>
    </view>
  </view>
</view>
<view class="tab-bar">
  <view class="tab-item active">首页</view>
  <view class="tab-item" bindtap="goMine">我的</view>
</view>