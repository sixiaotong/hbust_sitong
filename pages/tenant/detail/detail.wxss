/* pages/tenant/detail/detail.wxss */
.detail-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 120rpx;
}

/* 轮播图 */
.house-swiper {
  width: 100%;
  height: 500rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

/* 信息卡片 */
.info-card {
  background: white;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.price-section {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.price-main {
  font-size: 56rpx;
  font-weight: bold;
  color: #ff6b35;
  margin-right: 10rpx;
}

.price-unit {
  font-size: 28rpx;
  color: #999;
}

.tag-list {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
}

.tag {
  background: #e8f5e9;
  color: #09BB07;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.title-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
}

.house-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  margin-right: 20rpx;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.action-icon {
  font-size: 40rpx;
}

.action-text {
  font-size: 22rpx;
  color: #666;
}

.action-btn.active .action-text {
  color: #ff6b35;
}

.location-section {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.location-icon {
  font-size: 32rpx;
  margin-right: 15rpx;
  color: #007AFF;
}

.location-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.copy-btn {
  color: #007AFF;
  font-size: 26rpx;
  padding: 10rpx 20rpx;
  background: rgba(0, 122, 255, 0.1);
  border-radius: 20rpx;
}

/* 详情卡片 */
.detail-card {
  background: white;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 25rpx;
  display: flex;
  align-items: center;
}

.title-icon {
  margin-right: 15rpx;
  font-size: 36rpx;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.item-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
}

.item-label {
  flex: 1;
  font-size: 26rpx;
  color: #666;
}

.item-value {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.description {
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.desc-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
}

.desc-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 评论卡片 */
.comment-card {
  background: white;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.comment-list {
  margin-bottom: 30rpx;
}

.comment-item {
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-header {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.user-avatar {
  width: 60rpx;
  height: 60rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 15rpx;
  font-size: 30rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 5rpx;
}

.comment-time {
  font-size: 24rpx;
  color: #999;
}

.comment-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.empty-comments {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  margin-bottom: 30rpx;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.3;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.comment-input-box {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.comment-input {
  flex: 1;
  background: #f8f9fa;
  border-radius: 25rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
  color: #333;
}

.send-btn {
  background: #ccc;
  color: white;
  border-radius: 25rpx;
  width: 120rpx;
  height: 70rpx;
  font-size: 28rpx;
  border: none;
}

.send-btn.active {
  background: #007AFF;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: white;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  border-top: 1rpx solid #f0f0f0;
  z-index: 1000;
  padding-bottom: env(safe-area-inset-bottom);
}

.contact-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  border-right: 1rpx solid #f0f0f0;
}

.contact-icon {
  font-size: 36rpx;
  margin-bottom: 5rpx;
}

.contact-text {
  font-size: 24rpx;
  color: #333;
}

.order-btn {
  flex: 2;
  background: linear-gradient(135deg, #ff6b35, #ff8c00);
  color: white;
  border-radius: 50rpx;
  height: 80rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 10rpx;
}

.order-icon {
  margin-right: 10rpx;
  font-size: 36rpx;
}

/* 分享面板 */
.share-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 2000;
}

.share-panel {
  background: white;
  width: 100%;
  border-radius: 30rpx 30rpx 0 0;
  padding: 40rpx 0;
}

.share-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 40rpx;
}

.share-options {
  display: flex;
  justify-content: space-around;
  margin-bottom: 40rpx;
}

.share-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: none;
  border: none;
  padding: 0;
}

.share-icon {
  font-size: 80rpx;
  margin-bottom: 15rpx;
}

.share-text {
  font-size: 26rpx;
  color: #333;
}

.share-cancel {
  text-align: center;
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
  font-size: 32rpx;
  color: #007AFF;
}