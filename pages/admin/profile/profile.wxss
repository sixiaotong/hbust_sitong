/* 音乐播放器卡片 */
.music-player {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
  color: #fff !important;
  transition: all 0.3s;
}

.music-player.playing {
  box-shadow: 0 8rpx 20rpx rgba(118, 75, 162, 0.4);
}

.music-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.music-info {
  flex: 1;
}

.song-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
}

.song-status {
  font-size: 22rpx;
  opacity: 0.8;
}

/* 简单的跳动动画 */
.music-animation {
  display: flex;
  align-items: flex-end;
  height: 30rpx;
}

.bar {
  width: 4rpx;
  height: 10rpx;
  background: #fff;
  margin-left: 4rpx;
  animation: dance 0.6s infinite alternate;
}

.bar:nth-child(2) { animation-delay: 0.2s; }
.bar:nth-child(3) { animation-delay: 0.4s; }

@keyframes dance {
  from { height: 10rpx; }
  to { height: 30rpx; }
}