/* 在对应的wxss文件中添加样式 */
.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: relative;
  overflow: hidden;
}

/* 背景装饰元素 */
.bg-decoration {
  position: absolute;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  animation: float 20s infinite linear;
}

.circle-1 {
  width: 300rpx;
  height: 300rpx;
  top: -150rpx;
  left: -150rpx;
  animation-delay: 0s;
}

.circle-2 {
  width: 200rpx;
  height: 200rpx;
  top: 30%;
  right: -100rpx;
  animation-delay: -5s;
}

.circle-3 {
  width: 150rpx;
  height: 150rpx;
  bottom: 20%;
  left: -75rpx;
  animation-delay: -10s;
}

.circle-4 {
  width: 100rpx;
  height: 100rpx;
  bottom: 10%;
  right: 20%;
  animation-delay: -15s;
}

.shape {
  position: absolute;
  background: rgba(255, 255, 255, 0.05);
}

.shape-1 {
  width: 400rpx;
  height: 400rpx;
  border-radius: 40rpx;
  transform: rotate(45deg);
  top: 10%;
  right: -200rpx;
  animation: rotate 30s infinite linear;
}

.shape-2 {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50% 20% 50% 20%;
  bottom: -100rpx;
  left: -100rpx;
  animation: pulse 4s infinite ease-in-out;
}

@keyframes float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-20rpx) rotate(180deg); }
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 0.5; }
  50% { transform: scale(1.1); opacity: 0.7; }
}

@keyframes slideup {
  from { transform: translateY(50rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.animate-slideup {
  animation: slideup 0.6s ease-out;
}

/* 头部样式 */
.header {
  padding: 60rpx 40rpx 40rpx;
  color: white;
}

.logo-wrapper {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.logo-icon {
  font-size: 80rpx;
  margin-right: 20rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.2));
}

.logo-text {
  display: flex;
  flex-direction: column;
}

.logo-main {
  font-size: 48rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.logo-sub {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 4rpx;
}

.welcome-text {
  font-size: 36rpx;
  font-weight: 300;
  opacity: 0.95;
  margin-top: 10rpx;
}

/* 登录表单样式 */
.login-box {
  background: white;
  border-radius: 40rpx 40rpx 0 0;
  margin-top: 40rpx;
  min-height: 80vh;
  position: relative;
  overflow: hidden;
  box-shadow: 0 -10rpx 40rpx rgba(0,0,0,0.1);
}

.login-header {
  padding: 40rpx 40rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.role-tag {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4edf5 100%);
  padding: 12rpx 24rpx;
  border-radius: 50rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.role-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.role-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.progress-dots {
  display: flex;
  gap: 12rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #e0e0e0;
}

.dot.active {
  background: #007AFF;
  transform: scale(1.2);
}

/* 表单内容 */
.form-container {
  padding: 20rpx 40rpx 40rpx;
}

.input-wrapper {
  position: relative;
  margin-bottom: 50rpx;
  padding-top: 30rpx;
}

.input-icon {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  font-size: 40rpx;
  color: #666;
  z-index: 2;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 60rpx;
  font-size: 32rpx;
  color: #333;
  background: transparent;
  border: none;
  outline: none;
  z-index: 1;
  position: relative;
}

.input-line {
  position: absolute;
  bottom: 0;
  left: 60rpx;
  right: 0;
  height: 2rpx;
  background: #e0e0e0;
  transition: all 0.3s;
}

.form-input:focus + .input-line {
  height: 4rpx;
  background: linear-gradient(90deg, #007AFF, #00D4FF);
  box-shadow: 0 2rpx 8rpx rgba(0, 122, 255, 0.3);
}

.password-toggle {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  padding: 20rpx;
  font-size: 36rpx;
  color: #666;
  cursor: pointer;
}

.quick-login-btn {
  background: linear-gradient(135deg, #fff8e1 0%, #ffecb3 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  overflow: hidden;
  border: 2rpx dashed #ff9800;
  cursor: pointer;
  transition: all 0.3s;
}

.quick-login-btn:active {
  transform: scale(0.98);
}

.test-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background: #ff9800;
  color: white;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: bold;
}

.quick-login-btn text {
  color: #ff6d00;
  font-size: 28rpx;
  font-weight: 500;
}

.test-account {
  font-size: 24rpx;
  color: #ff9800;
  margin-top: 8rpx;
  opacity: 0.8;
}

/* 登录按钮 */
.gradient-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: none;
  border-radius: 25rpx;
  height: 90rpx;
  color: white;
  font-size: 34rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 50rpx 0 30rpx;
  box-shadow: 0 8rpx 25rpx rgba(102, 126, 234, 0.4);
  position: relative;
  overflow: hidden;
  transition: all 0.3s;
}

.gradient-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  transition: left 0.5s;
}

.gradient-btn:hover::before {
  left: 100%;
}

.gradient-btn[disabled] {
  background: #ccc;
  box-shadow: none;
  opacity: 0.6;
}

.btn-text {
  margin-right: 10rpx;
}

.btn-icon {
  font-size: 40rpx;
  margin-left: 10rpx;
  transform: translateX(0);
  transition: transform 0.3s;
}

.btn-hover .btn-icon {
  transform: translateX(10rpx);
}

.back-to-role {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #666;
  font-size: 28rpx;
  margin-top: 30rpx;
  padding: 20rpx;
  cursor: pointer;
}

.back-icon {
  margin-right: 10rpx;
  font-size: 32rpx;
}

/* 角色选择卡片 */
.role-select-box {
  padding: 0 40rpx;
}

.section-header {
  margin-bottom: 50rpx;
}

.section-title {
  font-size: 42rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 10rpx;
}

.section-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.role-cards {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.role-card {
  background: white;
  border-radius: 30rpx;
  overflow: hidden;
  position: relative;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);
}

.card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  opacity: 0.05;
  transition: opacity 0.3s;
}

.tenant-card .card-bg {
  background: linear-gradient(135deg, #007AFF, #00D4FF);
}

.landlord-card .card-bg {
  background: linear-gradient(135deg, #09BB07, #8BC34A);
}

.admin-card .card-bg {
  background: linear-gradient(135deg, #E64340, #FF9800);
}

.role-card:hover .card-bg {
  opacity: 0.1;
}

.card-hover {
  transform: translateY(-8rpx) scale(1.02);
  box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.15);
}

.card-content {
  padding: 40rpx;
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.card-icon {
  font-size: 80rpx;
  margin-right: 30rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.1));
}

.card-info {
  flex: 1;
}

.card-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.tenant-card .card-title {
  color: #007AFF;
}

.landlord-card .card-title {
  color: #09BB07;
}

.admin-card .card-title {
  color: #E64340;
}

.card-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.card-features {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.feature {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(0,0,0,0.03);
  color: #555;
}

.select-arrow {
  font-size: 40rpx;
  color: #999;
  transition: all 0.3s;
}

.role-card:hover .select-arrow {
  color: #007AFF;
  transform: translateX(10rpx);
}

/* 提示框 */
.hint-box {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 50rpx;
  display: flex;
  align-items: flex-start;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.hint-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  color: #FFD700;
}

.hint-text {
  font-size: 26rpx;
  color: white;
  line-height: 1.4;
  flex: 1;
}

/* 页脚 */
.footer {
  padding: 40rpx 0 30rpx;
  position: relative;
}

.footer-wave {
  position: absolute;
  top: -50rpx;
  left: 0;
  right: 0;
  height: 50rpx;
  overflow: hidden;
}

.wave {
  position: absolute;
  width: 200%;
  height: 100rpx;
  background: url('data:image/svg+xml,<svg viewBox="0 0 1200 120" xmlns="http://www.w3.org/2000/svg"><path d="M0 0v46.29c47.79 22.2 103.59 32.17 158 28 70.36-5.37 136.33-33.31 206.8-37.5 73.84-4.36 147.54 16.88 218.2 35.26 69.27 18 138.3 24.88 209.4 13.08 36.15-6 69.85-17.84 104.45-29.34C989.49 25 1113-14.29 1200 52.47V0z" fill="white"/></svg>') repeat-x;
  animation: wave 12s cubic-bezier(0.36, 0.45, 0.63, 0.53) infinite;
}

@keyframes wave {
  0% { transform: translateX(0); }
  50% { transform: translateX(-25%); }
  100% { transform: translateX(-50%); }
}

.footer-text {
  display: block;
  text-align: center;
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  margin-top: 20rpx;
}

.footer-copyright {
  display: block;
  text-align: center;
  color: rgba(255, 255, 255, 0.6);
  font-size: 20rpx;
  margin-top: 10rpx;
}