/* 优化后的样式 */
.container {
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

/* 用户头部优化 */
.user-header {
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 0 0 24rpx 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: bold;
  margin-right: 24rpx;
}

.u-info {
  flex: 1;
}

.u-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.u-role {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 12rpx;
}

.publish-info {
  font-size: 28rpx;
}

.highlight {
  font-weight: bold;
  color: #ffd700;
  font-size: 32rpx;
}

/* 统计卡片 */
.stats-card {
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 20rpx;
  background: white;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: bold;
}

.subtitle {
  font-size: 24rpx;
  color: #999;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  background: #f8f9fa;
  padding: 24rpx;
  border-radius: 16rpx;
  text-align: center;
  transition: all 0.3s;
}

.stat-item:active {
  background: #e9ecef;
  transform: scale(0.98);
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.stat-trend {
  font-size: 20rpx;
  color: #52c41a;
}

.stat-subtext {
  font-size: 20rpx;
  color: #999;
}

.stats-footer {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

/* 发布记录 */
.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.see-all {
  color: #1890ff;
  font-size: 24rpx;
}

.recent-list {
  margin-bottom: 24rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #eee;
  transition: background 0.3s;
}

.record-item:active {
  background: #f5f5f5;
}

.record-info {
  flex: 1;
}

.house-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.house-meta {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 4rpx;
  display: block;
}

.publish-time {
  font-size: 22rpx;
  color: #999;
}

.record-status {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.status-1 { background: #e6f7ff; color: #1890ff; }
.status-2 { background: #f6ffed; color: #52c41a; }
.status-3 { background: #fff7e6; color: #fa8c16; }
.status-0 { background: #f5f5f5; color: #999; }

/* 列表项优化 */
.list {
  margin: 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background 0.3s;
}

.list-item:active {
  background: #f5f5f5;
}

.list-item:last-child {
  border-bottom: none;
}

.val {
  color: #1890ff;
  font-weight: 500;
}

.arrow {
  color: #999;
  font-size: 28rpx;
}

/* 按钮优化 */
.btn-out-container {
  margin: 40rpx 24rpx;
}

.btn-out {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: white;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
  border-radius: 44rpx;
  font-size: 28rpx;
}

.btn-out:active {
  background: #fff2f0;
}

/* Tab栏优化 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: white;
  padding: 16rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #666;
  padding: 12rpx;
  transition: color 0.3s;
}

.tab-item.active {
  color: #1890ff;
  font-weight: 500;
}

.tab-icon {
  display: block;
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

/* 模态框 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 32rpx;
  font-weight: bold;
}

.close {
  font-size: 40rpx;
  color: #999;
}