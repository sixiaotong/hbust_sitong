.container {
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  background: white;
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 10;
  border-bottom: 1rpx solid #f0f0f0;
}

.back-btn {
  font-size: 36rpx;
  color: #333;
  margin-right: 24rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.3s;
}

.back-btn:active {
  background: #f5f5f5;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.card {
  background: white;
  margin: 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.house-images {
  height: 400rpx;
}

.house-images swiper {
  height: 100%;
}

.house-images image {
  width: 100%;
  height: 100%;
}

.house-info {
  padding: 32rpx;
}

.house-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.house-price {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.price {
  font-size: 48rpx;
  font-weight: 800;
  color: #ff6b6b;
}

.unit {
  font-size: 28rpx;
  color: #999;
  margin-left: 8rpx;
}

.house-meta {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 24rpx;
}

.house-meta text {
  margin-right: 16rpx;
}

.house-status {
  display: inline-block;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
  padding: 32rpx 32rpx 0;
}

.info-grid {
  padding: 0 32rpx 32rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.info-item {
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.value {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.description {
  padding: 0 32rpx 32rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  padding: 32rpx;
  background: white;
  margin: 24rpx;
  border-radius: 20rpx;
}

.btn-edit, .btn-delete {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.btn-edit {
  background: #667eea;
  color: white;
}

.btn-edit:active {
  background: #5a67d8;
  transform: translateY(-2rpx);
}

.btn-delete {
  background: #ff6b6b;
  color: white;
}

.btn-delete:active {
  background: #fa5252;
  transform: translateY(-2rpx);
}