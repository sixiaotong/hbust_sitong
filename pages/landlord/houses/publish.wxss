.container {
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  background: white;
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 10;
  border-bottom: 1rpx solid #f0f0f0;
}

.back-btn {
  font-size: 36rpx;
  color: #333;
  margin-right: 24rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.3s;
}

.back-btn:active {
  background: #f5f5f5;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.form-container {
  height: calc(100vh - 240rpx);
  padding: 24rpx;
}

.form-group {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.label::after {
  content: '*';
  color: #ff6b6b;
  margin-left: 4rpx;
  display: none;
}

.label[data-required]::after {
  display: inline;
}

.input {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #333;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.input:focus {
  border-color: #667eea;
  background: white;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.row-inputs {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.input-small {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #333;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  text-align: center;
  border: 2rpx solid transparent;
}

.separator {
  font-size: 28rpx;
  color: #666;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: #333;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
  border: 2rpx solid transparent;
  line-height: 1.6;
  transition: all 0.3s;
}

.textarea:focus {
  border-color: #667eea;
  background: white;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-save, .btn-submit {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.btn-save {
  background: #f8f9fa;
  color: #666;
  border: 2rpx solid #e8e8e8;
}

.btn-save:active {
  background: #e9ecef;
  transform: translateY(-2rpx);
}

.btn-submit {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.3);
}

.btn-submit:active {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.4);
}

.btn-save[disabled], .btn-submit[disabled] {
  opacity: 0.5;
  transform: none !important;
}