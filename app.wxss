page { background: #f8f8f8; font-family: Helvetica, Arial, sans-serif; padding-bottom: 120rpx; }
.card { background: #fff; margin: 20rpx; border-radius: 12rpx; overflow: hidden; padding: 20rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05); }
.btn-primary { background: #007AFF; color: #fff; border-radius: 40rpx; margin: 20rpx 0; }
.tab-bar { position: fixed; bottom: 0; left: 0; right: 0; height: 100rpx; background: #fff; display: flex; border-top: 1rpx solid #eee; z-index: 10; }
.tab-item { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; font-size: 24rpx; color: #666; }
.tab-item.active { color: #007AFF; font-weight: bold; }
/* 房东端样式优化 */
.header { display: flex; justify-content: space-between; align-items: center; padding: 20rpx; }
.add-btn { font-size: 26rpx; background: #007AFF; color: #fff; margin: 0; padding: 10rpx 30rpx; }
.house-main { display: flex; }
.cover { width: 140rpx; height: 140rpx; border-radius: 8rpx; margin-right: 20rpx; }
.info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
.status { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 4rpx; width: fit-content; }
.status.pending { background: #fff7e6; color: #faad14; }
.status.approved { background: #f6ffed; color: #52c41a; }
.status.rejected { background: #fff1f0; color: #f5222d; }
.refuse-box { margin-top: 15rpx; color: #f5222d; font-size: 24rpx; background: #fff1f0; padding: 10rpx; border-radius: 4rpx; }

.form-item { display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #eee; }
.form-item text { width: 200rpx; }
.form-item-column { padding: 20rpx 0; }
.form-item-column textarea { width: 100%; background: #f9f9f9; padding: 20rpx; box-sizing: border-box; margin-top: 10rpx; }

.user-header { display: flex; align-items: center; padding: 60rpx 40rpx; }
.avatar { width: 100rpx; height: 100rpx; border-radius: 50%; background: #007AFF; color: #fff; font-size: 50rpx; text-align: center; line-height: 100rpx; margin-right: 30rpx; }
.u-name { font-size: 36rpx; font-weight: bold; }
.u-role { font-size: 24rpx; color: #999; }
.list-item { display: flex; justify-content: space-between; padding: 30rpx 0; border-bottom: 1rpx solid #f2f2f2; }
.btn-out { margin: 40rpx; color: #ff4d4f; border: 1rpx solid #ff4d4f; background: #fff; }
/* 管理员端样式 */
.admin-header { background: #007AFF; color: #fff; padding: 40rpx; }
.admin-header .title { font-size: 40rpx; font-weight: bold; display: block; }
.admin-header .subtitle { font-size: 24rpx; opacity: 0.8; margin-top: 10rpx; display: block; }

.pending-card { display: flex; align-items: center; border-left: 10rpx solid #faad14; }
.h-img { width: 120rpx; height: 120rpx; border-radius: 8rpx; }
.h-info { flex: 1; margin: 0 20rpx; }
.h-name { font-weight: bold; font-size: 30rpx; }
.h-tags { font-size: 24rpx; color: #666; margin-top: 6rpx; }
.h-landlord { font-size: 22rpx; color: #999; }
.action-hint { color: #007AFF; font-size: 24rpx; }
.empty-state { text-align: center; padding: 100rpx; color: #ccc; }

/* 审核详情页 */
.label { font-size: 24rpx; color: #999; margin-bottom: 20rpx; display: block; }
.reason-input { background: #f9f9f9; width: 100%; height: 200rpx; padding: 20rpx; box-sizing: border-box; border-radius: 8rpx; margin-top: 10rpx; }
.bottom-btns { position: fixed; bottom: 0; width: 100%; display: flex; padding: 30rpx; box-sizing: border-box; background: #fff; }
.btn-reject { flex: 1; margin-right: 20rpx; background: #fff1f0; color: #f5222d; border: 1rpx solid #ffa39e; }
.btn-approve { flex: 1; background: #52c41a; color: #fff; }

/* 管理员个人中心 */
.admin-info { display: flex; align-items: center; padding: 40rpx; }
.avatar-box { width: 100rpx; height: 100rpx; background: #faad14; color: #fff; border-radius: 50%; text-align: center; line-height: 100rpx; font-size: 40rpx; margin-right: 30rpx; }
.stat-grid { display: flex; padding: 40rpx 0; }
.stat-item { flex: 1; text-align: center; border-right: 1rpx solid #eee; }
.stat-item:last-child { border: none; }
.stat-item .num { font-size: 36rpx; font-weight: bold; color: #007AFF; }
.menu-item { padding: 30rpx 0; border-bottom: 1rpx solid #f2f2f2; display: flex; justify-content: space-between; }
.btn-logout { margin: 40rpx; background: #fff; color: #ff4d4f; border: 1rpx solid #ff4d4f; }
/* 顶部切换栏 */
.status-tabs {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 100;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}
.tab.active {
  color: #007AFF;
  font-weight: bold;
}
.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  width: 60%;
  height: 6rpx;
  background: #007AFF;
  border-radius: 3rpx;
}

/* 卡片不同状态的样式 */
.admin-card.approved { border-left: 10rpx solid #52c41a; }
.admin-card.rejected { border-left: 10rpx solid #f5222d; }
.admin-card.pending { border-left: 10rpx solid #faad14; }

.reason-tag {
  font-size: 22rpx;
  color: #f5222d;
  background: #fff1f0;
  padding: 4rpx 10rpx;
  margin-top: 10rpx;
  border-radius: 4rpx;
}

.stat-container { display: flex; padding: 40rpx 0 !important; }
.stat-box { flex: 1; text-align: center; }
.stat-box .num { font-size: 40rpx; font-weight: bold; }
.stat-box .num.blue { color: #007AFF; }
.stat-box .num.red { color: #f5222d; }
.stat-box .label { font-size: 24rpx; color: #999; margin-top: 10rpx; }

.badge {
  background: #ff4d4f;
  color: #fff;
  font-size: 22rpx;
  padding: 2rpx 14rpx;
  border-radius: 20rpx;
}